- !<Text/31ac7dd9-0d8e-4eab-8062-1b1387912189>
  PrefabRemaps:
    []
  Name: Text
  Enabled: true
  RenderOrder: 3
  StretchMode: Stretch
  VerticalAlignment: Top
  HorizontalAlignment: Left
  MeshShadowMode: None
  ShadowColor: {x: 1.000000, y: 1.000000, z: 1.000000, w: 1.000000}
  ShadowDensity: 1.000000
  Text: |-
    The depth of field effect will only work with
    devices that generate depth data.
    
    To see the depth effect in Lens Studio Preview
    panel, select a depth preview video.
    
    When depth data is not available, a user-defined
    black and white texture is automatically used
    to blur part of the screen.
    
    Check "Depth Controller [EDIT_ME]" object to
    control the depth effect.
